DATABASE_URL=postgres://postgres:postgres@localhost:5432/govbudget
# Use a dedicated test database. Never point this to the same DB as DATABASE_URL.
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/govbudget_test
JWT_SECRET=replace-with-strong-secret-at-least-32-characters
PORT=3000
FINAL_ENABLED=false
UPLOAD_MAX_MB=20

# Login rate limit (shared across all instances via DB table login_rate_limit_bucket)
# Backend: auto | redis | db. "auto" prefers Redis when REDIS_URL is configured.
LOGIN_RATE_LIMIT_BACKEND=auto
# Optional Redis endpoint for rate limiting (recommended for production).
REDIS_URL=redis://localhost:6379
# Redis key prefix for login limiter buckets.
LOGIN_RATE_LIMIT_REDIS_PREFIX=govbudget:login_rl
# Fallback DB cleanup interval for stale limiter buckets (ms).
LOGIN_RATE_LIMIT_DB_CLEANUP_INTERVAL_MS=300000
# Window length in milliseconds
LOGIN_RATE_LIMIT_WINDOW_MS=900000
# Max failed attempts per (IP + email) in one window
LOGIN_RATE_LIMIT_CREDENTIAL_MAX=8
# Max failed attempts per IP in one window
LOGIN_RATE_LIMIT_IP_MAX=200

# If behind Nginx/ALB/Ingress, set to 1 so req.ip uses X-Forwarded-For
TRUST_PROXY=1
# Request log switch and format: REQUEST_LOG=off|on, REQUEST_LOG_FORMAT=json|plain
REQUEST_LOG=on
REQUEST_LOG_FORMAT=json

# Prometheus metrics endpoint
# Set true to expose /metrics in Prometheus text format.
METRICS_ENABLED=true
# Optional bearer token for /metrics endpoint protection.
METRICS_TOKEN=
# Refresh interval for heavy custom metrics snapshots (ms).
METRICS_CACHE_MS=5000

# Report generation queue control (global via PG advisory lock)
# Max concurrent preview/generate jobs
REPORT_GENERATION_CONCURRENCY=2
# Max wait time for queued generation jobs (ms)
REPORT_GENERATION_QUEUE_TIMEOUT_MS=180000
# Queue polling interval (ms)
REPORT_GENERATION_QUEUE_POLL_MS=200
# Max retained wait/duration samples for queue metrics
REPORT_GENERATION_METRICS_SAMPLE_LIMIT=500

# Monitoring stack credentials (docker-compose monitoring profile)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me
